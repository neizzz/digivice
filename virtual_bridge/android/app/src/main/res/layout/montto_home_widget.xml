<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="true"
    android:clipToPadding="true">

    <ImageView
        android:id="@+id/widget_background_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_home_widget_day" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="6" />

                    <ViewFlipper
                        android:id="@+id/widget_character_flipper"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:translationY="4dp"
                        android:animateFirstView="false"
                        android:autoStart="true"
                        android:flipInterval="500"
                        android:inAnimation="@anim/widget_noop"
                        android:outAnimation="@anim/widget_noop">

                        <ImageView
                            android:id="@+id/widget_character_frame_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_home_widget_placeholder" />

                        <ImageView
                            android:id="@+id/widget_character_frame_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_home_widget_placeholder" />

                        <ImageView
                            android:id="@+id/widget_character_frame_3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_home_widget_placeholder" />

                        <ImageView
                            android:id="@+id/widget_character_frame_4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:adjustViewBounds="true"
                            android:contentDescription="@null"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_home_widget_placeholder" />
                    </ViewFlipper>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:contentDescription="@null" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_status_panel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:gravity="top|end"
            android:orientation="vertical"
            android:paddingTop="2dp">

            <ImageView
                android:id="@+id/widget_stamina_dot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="end"
                android:layout_marginEnd="4dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_home_widget_stamina_orange" />

            <LinearLayout
                android:id="@+id/widget_status_icon_row"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="end"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/widget_status_icon_1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/widget_status_icon_2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="2dp"
                    android:contentDescription="@null"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/widget_status_icon_3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="2dp"
                    android:contentDescription="@null"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/widget_status_icon_4"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="2dp"
                    android:contentDescription="@null"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_update_time_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|start"
            android:layout_marginStart="2dp"
            android:layout_marginBottom="2dp"
            android:background="#66000000"
            android:includeFontPadding="false"
            android:paddingHorizontal="4dp"
            android:paddingVertical="1dp"
            android:text="upd 00:00:00"
            android:textColor="#FFFFFFFF"
            android:textSize="10sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/widget_debug_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="2dp"
            android:layout_marginBottom="2dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <Button
                android:id="@+id/widget_debug_prev_button"
                android:layout_width="34dp"
                android:layout_height="24dp"
                android:layout_marginEnd="2dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="0dp"
                android:paddingVertical="0dp"
                android:text="Prev"
                android:textAllCaps="false"
                android:textSize="10sp" />

            <Button
                android:id="@+id/widget_debug_next_button"
                android:layout_width="34dp"
                android:layout_height="24dp"
                android:layout_marginEnd="2dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="0dp"
                android:paddingVertical="0dp"
                android:text="Next"
                android:textAllCaps="false"
                android:textSize="10sp" />

            <Button
                android:id="@+id/widget_debug_live_button"
                android:layout_width="34dp"
                android:layout_height="24dp"
                android:gravity="center"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="0dp"
                android:paddingVertical="0dp"
                android:text="Live"
                android:textAllCaps="false"
                android:textSize="10sp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
