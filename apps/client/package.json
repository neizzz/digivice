{
	"name": "@digivice/client",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite --host",
		"build": "pnpm --filter @digivice/game sync-assets && tsc -b && NODE_ENV=development vite build",
		"build:test": "pnpm --filter @digivice/game sync-assets && tsc -b && NODE_ENV=development NATIVE_FEATURE_TEST_MODE=true vite build",
		"build:flutter": "../../scripts/build-for-flutter.sh",
		"build:flutter:dev": "pnpm --filter @digivice/game sync-assets && tsc -b && vite build --mode flutter-dev",
		"dev:flutter": "../../scripts/watch-and-copy.sh",
		"lint": "eslint . --config eslint.config.js --no-config-lookup",
		"preview": "vite preview"
	},
	"dependencies": {
		"@digivice/game": "workspace:*",
		"@shared/storage": "workspace:*",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"tailwindcss": "^4.1.3",
		"uuid": "^11.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.15.0",
		"@tailwindcss/vite": "^4.1.3",
		"@types/node": "^22.13.9",
		"@types/react": "^19.1.0",
		"@types/react-dom": "^19.1.0",
		"@vitejs/plugin-react": "^4.3.4",
		"eslint": "^9.15.0",
		"eslint-plugin-react-hooks": "^5.0.0",
		"eslint-plugin-react-refresh": "^0.4.14",
		"globals": "^15.12.0",
		"typescript": "~5.6.2",
		"typescript-eslint": "^8.15.0",
		"vite": "^6.0.1",
		"vite-tsconfig-paths": "^5.1.4"
	}
}
